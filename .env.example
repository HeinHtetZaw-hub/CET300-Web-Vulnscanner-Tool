# VulnScanner environment configuration
# Copy this file to .env and adjust values before running docker compose.
# Docker Compose reads .env from the project root automatically for
# variable substitution (${VAR:-default} syntax in docker-compose.yml).

# ── Port overrides (defaults shown) ──────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=8000
DVWA_PORT=8080
JUICESHOP_PORT=3000

# ── Backend settings ──────────────────────────────────────────────────────────
RATE_LIMIT_RPS=10
HTTP_TIMEOUT=10.0

# DATABASE_URL is hard-coded in docker-compose.yml to use the named volume.
# Override here only if you switch to PostgreSQL (see below).
#
# PostgreSQL example (uncomment and set docker-compose.yml DATABASE_URL too):
# DATABASE_URL=postgresql+asyncpg://vulnscanner:secret@db:5432/vulnscanner
# POSTGRES_USER=vulnscanner
# POSTGRES_PASSWORD=secret
# POSTGRES_DB=vulnscanner
