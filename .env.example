# Copy this file to backend/.env and adjust values

# SQLite (default for dev)
DATABASE_URL=sqlite+aiosqlite:///./vulnscanner.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/vulnscanner

# Rate limit (requests per second)
RATE_LIMIT_RPS=10

# App version
APP_VERSION=1.0.0
